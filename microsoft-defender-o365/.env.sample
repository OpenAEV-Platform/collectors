### More env vars are defined in the example docker-compose.yml file
### with appropriate defaults.

# base URL to reach the OpenAEV server
# note this URL must be routable from inside the container
# so `localhost` will most likely not work
OPENAEV_URL=ChangeMe
# admin account API token from the OpenAEV server
OPENAEV_TOKEN=ChangeMe
# tenant identifier for multi-tenant deployments
# OPENAEV_TENANT_ID=ChangeMe

# collector ID must be a unique string, e.g. UUIDv4
COLLECTOR_ID=ChangeMe
# Name of the collector
# COLLECTOR_NAME=Template
# Type of security platform this collector works for
# COLLECTOR_PLATFORM=EDR
# Collection interval (ISO 8601 format)
# COLLECTOR_PERIOD=PT2M
# Determine the verbosity of the logs.
# COLLECTOR_LOG_LEVEL=error

# tenant identifier used to authenticate against Microsoft Graph (mandatory)
MICROSOFT_DEFENDER_O365_TENANT_ID=ChangeMe
# Azure AD application (client) identifier (mandatory)
MICROSOFT_DEFENDER_O365_CLIENT_ID=ChangeMe
# whether to authenticate using a client certificate instead of a client secret
# MICROSOFT_DEFENDER_O365_USE_CERTIFICATE_AUTH=false
# Azure AD application client secret (mandatory unless certificate auth is used)
MICROSOFT_DEFENDER_O365_CLIENT_SECRET=ChangeMe
# filesystem path to the client certificate (mandatory if certificate auth is used)
# MICROSOFT_DEFENDER_O365_CLIENT_CERT_PATH=ChangeMe
# thumbprint of the client certificate (mandatory if certificate auth is used)
# MICROSOFT_DEFENDER_O365_CLIENT_CERT_THUMBPRINT=ChangeMe
# base URL for the Microsoft Graph API
# MICROSOFT_DEFENDER_O365_BASE_URL=https://graph.microsoft.com/v1.0
# value used to filter Microsoft Graph security alerts down to Defender for Office 365 alerts
# MICROSOFT_DEFENDER_O365_FILTER_SERVICE_SOURCE=microsoftDefenderForOffice365
# maximum number of Microsoft Graph API requests issued per minute (must be >= 1)
# MICROSOFT_DEFENDER_O365_RATE_LIMIT_REQUESTS_PER_MINUTE=150
# maximum number of retries when fetching data from Microsoft Graph fails transiently
# MICROSOFT_DEFENDER_O365_MAX_FETCH_RETRIES=5
