OPENAEV_URL=ChangeMe
OPENAEV_TOKEN=ChangeMe
OPENAEV_TENANT_ID=ChangeMe

COLLECTOR_ID=ChangeMe
COLLECTOR_NAME=XTM One
COLLECTOR_PERIOD=PT1H
COLLECTOR_LOG_LEVEL=error

# Base URL of the XTM One platform (must be routable from the collector container)
COLLECTOR_XTM_ONE_URL=ChangeMe
# XTM One API key (fcp-...) used to read the agents and models catalog
COLLECTOR_XTM_ONE_TOKEN=ChangeMe
# Name of the injector env var holding the credential the AI red team injector
# uses at execution time. The secret value itself is never stored on the target.
COLLECTOR_XTM_ONE_API_KEY_VARIABLE=XTM_ONE_API_KEY
# When true, also create an AI target for each bare LLM model exposed by XTM One
COLLECTOR_INCLUDE_BARE_MODELS=false
# Comma-separated list of agent tags to scope on (empty = all agents)
COLLECTOR_AGENT_TAGS=
