OPENAEV_URL=ChangeMe
OPENAEV_TOKEN=ChangeMe
OPENAEV_TENANT_ID=ChangeMe

COLLECTOR_ID=ChangeMe
COLLECTOR_NAME=XTM One
# Security platform type registered in OpenAEV so XTM One shows up in the inventory
# as a security platform and expectation results are attributed to it (EDR, XDR,
# SIEM, SOAR, NDR, ISPM, LLM_FIREWALL, AI_GATEWAY).
COLLECTOR_PLATFORM=LLM_FIREWALL
# Scheduler loop: expectation validation runs on every cycle, so this is the
# expectation-matching cadence.
COLLECTOR_PERIOD=PT5M
# Minimum interval between two imports of the agents/models catalog (the import
# runs on the first cycle, then at most once per this period).
COLLECTOR_IMPORT_PERIOD=PT1H
COLLECTOR_LOG_LEVEL=error

# Base URL of the XTM One platform (must be routable from the collector container)
COLLECTOR_XTM_ONE_URL=ChangeMe
# XTM One API key (fcp-...): reads the agents/models catalog and the security audit
# log, and is stored on each seeded AI target. Validating detection expectations
# reads the admin-only audit log, so this key must belong to an XTM One admin.
COLLECTOR_XTM_ONE_TOKEN=ChangeMe
# When true, also validate AI detection/prevention expectations by matching
# "Prompt injection detected" audit events to the AI red team injects.
COLLECTOR_VALIDATE_EXPECTATIONS=true
# When true, also create an AI target for each bare LLM model exposed by XTM One
COLLECTOR_INCLUDE_BARE_MODELS=false
# Comma-separated list of agent tags to scope on (empty = all agents)
COLLECTOR_AGENT_TAGS=
