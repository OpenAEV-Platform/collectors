openaev:
  url: 'http://localhost:3001'
  token: 'ChangeMe'
  # tenant_id: 'ChangeMe'

collector:
  id: 'ChangeMe'   # unique collector instance identifier (UUIDv4 recommended)
  name: 'XTM One'
  platform: 'LLM_FIREWALL'   # security platform type registered in OpenAEV (EDR, XDR, SIEM, SOAR, NDR, ISPM, LLM_FIREWALL, AI_GATEWAY)
  period: 'PT5M'   # scheduler loop = expectation-matching cadence
  import_period: 'PT1H'   # minimum interval between two agents-catalog imports
  log_level: 'error'
  xtm_one_url: 'ChangeMe'   # base URL of the XTM One platform
  xtm_one_token: 'ChangeMe'   # XTM One API key (fcp-...): reads the catalog + audit log (admin key) and is stored on each seeded AI target
  validate_expectations: true   # match "Prompt injection detected" audit events to AI red team injects (needs an admin key)
  include_bare_models: false
  agent_tags: ''   # comma-separated agent tags to scope on (empty = all agents)
