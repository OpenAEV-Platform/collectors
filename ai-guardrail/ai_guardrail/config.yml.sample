openaev:
  url: 'http://localhost:3001'
  token: 'ChangeMe'
# tenant_id: 'ChangeMe'

collector:
  id: 'ChangeMe'   # unique UUIDv4
  name: 'AI Guardrail'
  platform: 'LLM_FIREWALL'   # or AI_GATEWAY
  period: 'PT60S'
  log_level: 'error'
  # AI defense backend
  provider: 'generic'        # generic | lakera | nemo
  events_url: 'http://my-ai-gateway:8080/decisions'  # queryable by the inject marker
# api_key: 'ChangeMe'
  lookback_minutes: 60
  marker_param: 'marker'
  flagged_field: 'flagged'
  blocked_field: 'blocked'
